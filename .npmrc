; Hoist typescript so @sveltejs/kit's sync can find it via `await import('typescript')`.
; Without this, pnpm's strict isolation hides typescript from kit's package dir
; and write_all_types silently no-ops, leaving routes without $types.d.ts and
; svelte-check spamming "Cannot find module './$types.js'" forever.
public-hoist-pattern[]=typescript
