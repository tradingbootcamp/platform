# WebSocket URL for the cohort you want to trade in.
# Local dev: ws://localhost:8080/api/ws/main
# Production: wss://exchange.trading.camp/api/ws/<cohort_name>
WS_URL=ws://localhost:8080/api/ws/main

# Your access token. Copy from the Accounts page → "Copy JWT" button.
# Tokens expire (typically ~1h); re-copy when the bot starts failing auth.
JWT=

# The account id the bot should trade as. Create an alt on the Accounts page,
# then copy its id with "Copy ACT_AS" while you're acting as it.
ACT_AS=

# The market id to trade. Get it from the URL of the market page.
MARKET_ID=

# (maker.ts only) Optional starting fair-value override. If unset, the maker
# initializes fv from the market midpoint at startup.
# FV_INIT=50
